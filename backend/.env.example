APP__NAME=novalearn-api
APP__ENV=docker
APP__DEBUG=true
APP__LOG_LEVEL=INFO
APP__API_PREFIX=/api/v1

SERVER__HOST=0.0.0.0
SERVER__PORT=8080
SERVER__CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

POSTGRES__DSN=postgresql+asyncpg://nova:pakistan@postgres:5432/novalearn
POSTGRES__ECHO=false
POSTGRES__POOL_SIZE=10
POSTGRES__MAX_OVERFLOW=20

LLM__API_KEY=
LLM__BASE_URL=https://openrouter.ai/api/v1
LLM__TIMEOUT_SECONDS=300
LLM__MAX_RETRIES=3

QDRANT__HOST=qdrant
QDRANT__PORT=6333
QDRANT__GRPC_PORT=6334
QDRANT__PREFER_GRPC=true
QDRANT__TIMEOUT=15
QDRANT__VECTOR_SIZE=1024

S3__ENDPOINT_URL=
S3__ACCESS_KEY_ID=
S3__SECRET_ACCESS_KEY=
S3__REGION=eu-central-1
S3__BUCKET=novalearn-assets
S3__USE_SSL=true
S3__USE_PATH_STYLE=false
# Optional: when the backend reaches S3 via a Docker-internal hostname
# (e.g. http://minio:9000) but presigned URLs need to point at a host the
# browser can reach (e.g. http://localhost:9000), set this to the
# browser-facing endpoint. Leave empty to use S3__ENDPOINT_URL.
S3__PUBLIC_ENDPOINT_URL=

RABBITMQ__URL=amqp://guest:guest@rabbitmq:5672/

AUTH__SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH__REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH__DEV_BYPASS_ENABLED=true
AUTH__DEV_BYPASS_EMAIL=dev@novalearn.local
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# Google OAuth (Web client)
AUTH__GOOGLE__ENABLED=true
AUTH__GOOGLE__CLIENT_ID=
AUTH__GOOGLE__CLIENT_SECRET=
AUTH__GOOGLE__REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback
AUTH__GOOGLE__FRONTEND_REDIRECT_URL=http://localhost:3000/auth/callback

# Mail (Resend HTTPS API)
MAIL__API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
MAIL__API_URL=https://api.resend.com
MAIL__FROM_EMAIL=noreply@novalearn.app
MAIL__FROM_NAME=NovaLearn
MAIL__MAX_CODE_ATTEMPTS=5
MAIL__MAX_TOKEN_ATTEMPTS=5
MAIL__MAX_SENDS_PER_HOUR=5
MAIL__LOCKOUT_MINUTES=15

VOYAGE__API_KEY=
VOYAGE__OUTPUT_DIMENSION=1024

MISTRAL__API_KEY=
MISTRAL__OCR_MODEL=mistral-ocr-latest

GENAI__API_KEY=
GENAI__EMBEDDING_MODEL=gemini-embedding-2-preview

PROCESSING__STREAM_INTERVAL_SECONDS=1
PROCESSING__MAX_PARALLEL=4
PROCESSING__MAX_ATTEMPTS=3
PROCESSING__TXT_WRAP_MAX_LENGTH=100

POSTGRES_USER=nova
POSTGRES_PASSWORD=pakistan
POSTGRES_DB=novalearn

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
